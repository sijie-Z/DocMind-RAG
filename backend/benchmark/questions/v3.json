{
  "meta": {
    "version": 2,
    "description": "DocMind Benchmark — 三层评测结构",
    "layers": {
      "L1_capability": {
        "name": "能力测试",
        "question_count": 20,
        "target": "验证 Agent 架构为什么比纯 RAG 强",
        "metrics": [
          "keyword_coverage",
          "completion",
          "step_efficiency"
        ]
      },
      "L2_system": {
        "name": "系统测试",
        "question_count": 10,
        "target": "验证 Agent 在异常条件下的鲁棒性和恢复能力",
        "metrics": [
          "completion",
          "graceful_degradation",
          "recovery_attempts"
        ]
      },
      "L3_casestudy": {
        "name": "案例研究",
        "question_count": 0,
        "target": "用真实 Trace 分析失败原因并验证优化效果",
        "metrics": [
          "trace_url",
          "root_cause",
          "optimization",
          "delta"
        ],
        "note": "运行 Benchmark 后从 failure/partial 中挑选，部署后补充"
      }
    }
  },
