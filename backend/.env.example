# AI Model Configuration
# 1. Chat Model (DeepSeek)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 2. Embedding Model (Vectorization)
# Note: DeepSeek API usually handles Chat. For Embeddings, we recommend OpenAI or Local.
# If you leave these blank, the system will use Mock Embeddings (Random numbers).
EMBEDDING_API_KEY=sk-your-openai-key-here
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small

# 3. Infrastructure (Docker Defaults)
DATABASE_URL=mysql+aiomysql://root:root@localhost:3307/paicongming_db
REDIS_HOST=localhost
ELASTICSEARCH_HOSTS=["http://localhost:9200"]
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MINIO_ENDPOINT=localhost:9000
