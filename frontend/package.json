{
  "name": "docmind-frontend",
  "version": "1.0.0",
  "description": "DocMind 企业级 RAG 知识库前端 - Vue 3 + TypeScript + Naive UI",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "api:generate": "openapi --input http://localhost:8000/openapi.json --output src/api/generated --client axios"
  },
  "dependencies": {
    "@iconify/vue": "^4.1.1",
    "@vicons/ionicons5": "^0.13.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^10.7.0",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "dompurify": "^3.3.1",
    "echarts": "^5.6.0",
    "highlight.js": "^11.11.1",
    "js-cookie": "^3.0.5",
    "katex": "^0.16.28",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.1.1",
    "markdown-it-highlightjs": "^4.3.0",
    "markdown-it-katex": "^2.0.3",
    "naive-ui": "^2.38.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.3",
    "vue": "^3.4.0",
    "vue-i18n": "^9.8.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/highlight.js": "^9.12.4",
    "@types/js-cookie": "^3.0.6",
    "@types/katex": "^0.16.8",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.10.5",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "openapi-typescript-codegen": "^0.30.0",
    "terser": "^5.46.1",
    "typescript": "^5.3.3",
    "unocss": "^0.58.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^9.3.2",
    "vue-tsc": "^3.3.2",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  }
}
